# ============================================================
# AiCruzz - Environment Variables
# Copy this to .env and fill in all values
# ============================================================

# ─── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://aicruzz:aicruzz_pass@localhost:5432/aicruzz_db

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── AI Providers ──────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNWAY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PIKA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Crypto Wallets (Admin Receiving Addresses) ────────────
ADMIN_WALLET_BTC=bc1qxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_WALLET_USDT=Txxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── File Upload ───────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Credit System ─────────────────────────────────────────
CREDITS_PER_DOLLAR=10
CREDIT_EXPIRY_DAYS=30
MIN_FUND_AMOUNT=10

# ─── AI Router (internal service) ───────────────────────────
AI_ROUTER_URL=http://localhost:4001
AI_ROUTER_SECRET=change_me_ai_router_secret_32chars_min
AI_ROUTER_PORT=4001
GPU_WORKER_URL=http://localhost:8000
QUEUE_CONCURRENCY=4
